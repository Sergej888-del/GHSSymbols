---
// Базовый layout для всех страниц ghssymbols.com
import '../styles/global.css'

interface Props {
  title: string
  description?: string
  canonical?: string
}

const {
  title,
  description = 'GHS hazard symbols, H-statements, ATE calculator and chemical safety tools for EHS professionals.',
  canonical
} = Astro.props

const siteUrl = 'https://ghssymbols.com'
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title} | GHS Symbols</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | GHS Symbols`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
  </head>
  <body class="bg-white text-gray-900 font-sans antialiased">
    <!-- Навигация -->
    <header class="border-b border-gray-200 bg-white sticky top-0 z-50">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 font-bold text-xl text-orange-600">
          GHS Symbols
        </a>
        <ul class="hidden md:flex items-center gap-6 text-sm font-medium text-gray-600">
          <li><a href="/tools/ate-calculator" class="hover:text-orange-600 transition-colors">ATE Calculator</a></li>
          <li><a href="/tools/storage-matrix" class="hover:text-orange-600 transition-colors">Storage Matrix</a></li>
          <li><a href="/hazards" class="hover:text-orange-600 transition-colors">Hazards DB</a></li>
        </ul>
      </nav>
    </header>

    <!-- Основной контент -->
    <main>
      <slot />
    </main>

    <!-- Футер -->
    <footer class="border-t border-gray-200 mt-24 py-12 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-sm text-gray-500 text-center">
        <p>© 2026 GHS Symbols. Chemical safety tools for EHS professionals.</p>
        <p class="mt-2">
          Data source: <a href="https://echa.europa.eu" class="underline hover:text-gray-700">ECHA CLP Annex VI</a>
        </p>
      </div>
    </footer>
  </body>
</html>
