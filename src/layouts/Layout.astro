---
// Базовый layout для всех страниц ghssymbols.com
import '../styles/global.css'

interface Props {
  title: string
  description?: string
  canonical?: string
  /** Если true — в title и og:title только `title`, без « | GHS Symbols» (SEO-строка уже полная). */
  titleIsComplete?: boolean
}

const {
  title,
  description = 'GHS hazard symbols, H-statements, ATE calculator and chemical safety tools for EHS professionals.',
  canonical,
  titleIsComplete = false,
} = Astro.props

const pageTitle = titleIsComplete ? title : `${title} | GHS Symbols`

const siteUrl = 'https://ghssymbols.com'
const base = Astro.site ?? siteUrl

/** Canonical должен совпадать с финальным URL Cloudflare (trailing slash), иначе «canonical → redirect». */
function ensureTrailingSlashUrl(href: string): string {
  const u = new URL(href)
  if (u.pathname !== '/' && !u.pathname.endsWith('/')) {
    u.pathname += '/'
  }
  return u.href
}

const rawPath = Astro.url.pathname
const pathWithSlash = rawPath.endsWith('/') ? rawPath : rawPath + '/'
const canonicalURL = canonical
  ? ensureTrailingSlashUrl(canonical)
  : new URL(pathWithSlash, base).href
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <title>{pageTitle}</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <slot name="head" />
    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-1Y5MKV5XMK"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-1Y5MKV5XMK');
    </script>
  </head>
  <body class="bg-white text-gray-900 font-sans antialiased">
    <!-- Навигация -->
    <header class="bg-[#062A78] sticky top-0 z-50">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 font-bold text-xl text-white">
          GHS Symbols
        </a>

        <!-- Десктоп меню -->
        <ul class="hidden md:flex items-center gap-6 text-sm font-medium text-blue-200">
          <li><a href="/tools/ate-calculator" class="hover:text-white transition-colors">ATE Calculator</a></li>
          <li><a href="/tools/storage-matrix" class="hover:text-white transition-colors">Storage Matrix</a></li>
          <li><a href="/hazards" class="hover:text-white transition-colors">Hazards DB</a></li>
          <li><a href="/h-statements" class="hover:text-white transition-colors">H-Statements</a></li>
          <li><a href="/p-statements" class="hover:text-white transition-colors">P-Statements</a></li>
          <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
          <li><a href="/faq" class="hover:text-white transition-colors">FAQ</a></li>
        </ul>

        <!-- Бургер-меню для мобильных -->
        <details class="md:hidden relative">
          <summary class="list-none cursor-pointer p-2 text-blue-200 hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </summary>
          <ul class="absolute right-0 top-full mt-1 w-52 bg-[#062A78] border border-blue-700 rounded-xl shadow-xl py-2 text-sm font-medium text-blue-200">
            <li><a href="/tools/ate-calculator" class="block px-5 py-3 hover:bg-blue-800 hover:text-white transition-colors">ATE Calculator</a></li>
            <li><a href="/tools/storage-matrix" class="block px-5 py-3 hover:bg-blue-800 hover:text-white transition-colors">Storage Matrix</a></li>
            <li><a href="/hazards" class="block px-5 py-3 hover:bg-blue-800 hover:text-white transition-colors">Hazards DB</a></li>
            <li><a href="/h-statements" class="block px-5 py-3 hover:bg-blue-800 hover:text-white transition-colors">H-Statements</a></li>
            <li><a href="/p-statements" class="block px-5 py-3 hover:bg-blue-800 hover:text-white transition-colors">P-Statements</a></li>
            <li><a href="/blog" class="block px-5 py-3 hover:bg-blue-800 hover:text-white transition-colors">Blog</a></li>
            <li><a href="/faq" class="block px-5 py-3 hover:bg-blue-800 hover:text-white transition-colors">FAQ</a></li>
          </ul>
        </details>
      </nav>
    </header>

    <div class="bg-blue-950 text-blue-200 text-sm py-1.5">
      <div class="max-w-7xl mx-auto px-4 flex items-center justify-center gap-6 flex-wrap">
        <span class="text-blue-400 font-medium">GHS Ecosystem:</span>
        <span class="text-blue-300">▶ You are on GHS Symbols</span>
        <a href="https://ghspictograms.com" class="hover:text-white transition-colors flex items-center gap-1">
          GHS Pictograms <span class="text-blue-500">→ Labels & SVG Downloads</span>
        </a>
        <a href="https://ghslabels.com" class="hover:text-white transition-colors flex items-center gap-1">
          GHS Labels <span class="text-amber-400">→ Order Certified GHS Labels</span>
        </a>
      </div>
    </div>

    <!-- Основной контент -->
    <main>
      <slot />
    </main>

    <!-- Футер -->
    <footer class="bg-[#062A78] mt-24 py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-sm text-blue-200 text-center">
        <p class="text-white font-semibold mb-2">GHS Symbols</p>
        <p>Chemical safety tools for EHS professionals.</p>
        <p class="mt-2">
          Data source: <a href="https://echa.europa.eu" class="underline hover:text-white">ECHA CLP Annex VI</a>
        </p>
        <p class="mt-4 text-blue-300">© 2026 GHS Symbols</p>
      </div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8 pt-6 border-t border-blue-800">
        <p class="text-xs text-blue-400 text-center leading-relaxed">
          <strong class="text-blue-300">Disclaimer:</strong> All information provided on this website is for reference purposes only.
          GHS classifications, H-statements, P-statements and ATE calculations are based on
          publicly available data and should not be used as a substitute for professional
          chemical safety assessment. Always consult official Safety Data Sheets (SDS) and
          qualified EHS professionals. The manufacturer or formulator bears full responsibility
          for final GHS classification of their products.
        </p>
      </div>
    </footer>
  </body>
</html>
