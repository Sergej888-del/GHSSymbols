---
import Layout from '../../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
)
---

<Layout
  title="Blog — GHS Chemical Safety"
  description="Articles on GHS hazard classification, ATE calculations, CLP compliance and chemical safety for EHS professionals."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <h1 class="text-4xl font-bold text-gray-900 mb-3">Blog</h1>
    <p class="text-gray-500 mb-12">GHS, CLP and chemical safety for EHS professionals.</p>

    <div class="space-y-8">
      {posts.map(post => (
        <a
          href={`/blog/${post.id}/`}
          class="group block border border-gray-200 rounded-2xl p-8 hover:border-blue-300 hover:shadow-md transition-all"
        >
          <div class="flex flex-wrap gap-2 mb-3">
            {post.data.tags.map((tag: string) => (
              <span class="text-xs font-medium px-2 py-0.5 bg-blue-50 text-blue-700 rounded-full">
                {tag}
              </span>
            ))}
          </div>
          <h2 class="text-xl font-bold text-gray-900 group-hover:text-blue-700 transition-colors mb-2">
            {post.data.title}
          </h2>
          <p class="text-gray-500 text-sm mb-4">{post.data.description}</p>
          <div class="flex items-center gap-3 text-xs text-gray-400">
            <span>{post.data.author}</span>
            <span>·</span>
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
            </time>
          </div>
        </a>
      ))}
    </div>

  </div>
</Layout>
