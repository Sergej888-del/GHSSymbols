---
import Layout from '../../layouts/Layout.astro'
import { supabase } from '../../lib/supabase'

const siteUrl = 'https://ghssymbols.com'

export async function getStaticPaths() {
  const { data } = await supabase.from('p_statements').select('code')
  return (data ?? []).map((r) => ({
    params: { code: r.code },
  }))
}

const rawCode = Astro.params.code ?? ''
const code = decodeURIComponent(rawCode)

const { data: row } = await supabase.from('p_statements').select('*').eq('code', code).maybeSingle()

if (!row) {
  return Astro.redirect('/p-statements/')
}

const p = row as {
  code: string
  category: string
  text_en: string
  text_ru: string | null
  text_lv: string | null
  text_de: string | null
  ghs_revision: number | null
}

const { data: subs } = await supabase
  .from('substances')
  .select('cas_number, common_name, iupac_name')
  .contains('p_statement_codes', [code])
  .not('cas_number', 'is', null)
  .order('iupac_name', { ascending: true })
  .limit(50)

const substances = (subs ?? []) as { cas_number: string; common_name: string | null; iupac_name: string }[]
const displayName = (s: (typeof substances)[0]) => s.common_name || s.iupac_name

const { data: allCodeRows } = await supabase.from('p_statements').select('code').order('code', { ascending: true })
const orderedCodes = (allCodeRows ?? []).map((r) => r.code)
const idx = orderedCodes.indexOf(code)
const prevCode = idx > 0 ? orderedCodes[idx - 1] : null
const nextCode = idx >= 0 && idx < orderedCodes.length - 1 ? orderedCodes[idx + 1] : null

const title = `${p.code} Precautionary Statement — GHS/CLP Definition and Examples`
const description = `${p.code}: ${p.text_en.slice(0, 140)}${p.text_en.length > 140 ? '…' : ''} See which substances include this precautionary statement.`
const canonical = `${siteUrl}/p-statements/${encodeURIComponent(p.code)}/`

const definedTermJson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  name: p.code,
  description: p.text_en,
  inDefinedTermSet: {
    '@type': 'DefinedTermSet',
    name: 'GHS Precautionary Statements',
    url: `${siteUrl}/p-statements/`,
  },
})
---

<Layout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" slot="head" set:html={definedTermJson} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <nav class="text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
      <a href="/" class="text-[#062A78] hover:underline">Home</a>
      <span class="mx-2">→</span>
      <a href="/p-statements/" class="text-[#062A78] hover:underline">P-Statements</a>
      <span class="mx-2">→</span>
      <span class="text-gray-700 font-mono font-semibold">{p.code}</span>
    </nav>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 leading-snug">
      <span class="text-blue-700 font-mono">{p.code}</span>
      <span class="text-gray-400 font-normal mx-2">—</span>
      <span>{p.text_en}</span>
    </h1>

    <div class="mt-8 rounded-xl bg-gray-50 border border-gray-200 p-6 space-y-4 text-sm">
      <p>
        <span class="font-semibold text-gray-700">Category:</span>{' '}
        <span class="text-gray-900">{p.category}</span>
      </p>
      <p>
        <span class="font-semibold text-gray-700">GHS Revision:</span>{' '}
        <span class="text-gray-900">{p.ghs_revision ?? '—'}</span>
      </p>
      <div>
        <p class="font-semibold text-gray-700 mb-1">Full text (EN)</p>
        <p class="text-gray-900 leading-relaxed">{p.text_en}</p>
      </div>
      <div>
        <p class="font-semibold text-gray-700 mb-1">Latvian</p>
        <p class="text-gray-800 leading-relaxed">{p.text_lv ?? '—'}</p>
      </div>
      <div>
        <p class="font-semibold text-gray-700 mb-1">Russian</p>
        <p class="text-gray-800 leading-relaxed">{p.text_ru ?? '—'}</p>
      </div>
      <div>
        <p class="font-semibold text-gray-700 mb-1">German</p>
        <p class="text-gray-800 leading-relaxed">{p.text_de ?? '—'}</p>
      </div>
    </div>

    <section class="mt-12">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Substances with {p.code}</h2>
      {substances.length === 0 ? (
        <p class="text-gray-600">No substances in our database currently carry this statement.</p>
      ) : (
        <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
          <table class="min-w-full text-sm border-collapse">
            <thead>
              <tr class="bg-gray-100 text-left">
                <th class="px-4 py-3 font-semibold border-b border-gray-200">CAS Number</th>
                <th class="px-4 py-3 font-semibold border-b border-gray-200">Name</th>
              </tr>
            </thead>
            <tbody>
              {substances.map((s) => (
                <tr class="border-b border-gray-100 hover:bg-gray-50">
                  <td class="px-4 py-3 font-mono text-blue-700 font-semibold whitespace-nowrap">
                    <a href={`/hazards/${encodeURIComponent(s.cas_number)}/`} class="hover:underline">
                      {s.cas_number}
                    </a>
                  </td>
                  <td class="px-4 py-3 text-gray-800">
                    <a href={`/hazards/${encodeURIComponent(s.cas_number)}/`} class="hover:text-[#062A78] hover:underline">
                      {displayName(s)}
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
      {substances.length >= 50 && (
        <p class="mt-3 text-sm text-gray-500">Showing first 50 substances (alphabetically by IUPAC name).</p>
      )}
    </section>

    <nav class="mt-10 flex flex-wrap justify-between gap-4 text-sm border-t border-gray-200 pt-8">
      {prevCode ? (
        <a href={`/p-statements/${encodeURIComponent(prevCode)}/`} class="text-[#062A78] font-semibold hover:underline">
          ← Previous {prevCode}
        </a>
      ) : (
        <span class="text-gray-400">← Previous</span>
      )}
      {nextCode ? (
        <a href={`/p-statements/${encodeURIComponent(nextCode)}/`} class="text-[#062A78] font-semibold hover:underline">
          Next {nextCode} →
        </a>
      ) : (
        <span class="text-gray-400">Next →</span>
      )}
    </nav>

    <p class="mt-10 text-center">
      <a href="/hazards/" class="text-[#062A78] font-semibold hover:underline inline-flex items-center gap-1">
        Explore related substances in our GHS Hazard Database →
      </a>
    </p>
  </div>
</Layout>
