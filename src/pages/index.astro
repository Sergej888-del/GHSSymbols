---
// Главная страница ghssymbols.com
import Layout from '../layouts/Layout.astro'
---

<Layout
  title="GHS Hazard Symbols & Chemical Safety Tools"
  description="Free GHS/CLP tools for EHS professionals: ATE mixture toxicity calculator, chemical storage compatibility matrix, H-statements database."
>
  <!-- Hero секция -->
  <section class="bg-gradient-to-br from-slate-900 to-blue-950 py-24 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-white leading-tight">
        GHS Hazard Symbols &<br />
        <span class="text-orange-400">Chemical Safety Tools</span>
      </h1>
      <p class="mt-6 text-xl text-slate-300 max-w-2xl mx-auto">
        Professional tools for EHS specialists: calculate mixture toxicity,
        check chemical storage compatibility, look up H/P-statements.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/tools/ate-calculator"
          class="bg-orange-500 text-white px-8 py-3 rounded-lg font-semibold hover:bg-orange-600 transition-colors"
        >
          ATE Calculator
        </a>
        <a
          href="/hazards"
          class="bg-white text-slate-900 px-8 py-3 rounded-lg font-semibold hover:bg-slate-100 transition-colors"
        >
          Browse 5,000+ Chemicals →
        </a>
      </div>
    </div>
  </section>

  <!-- Карточки инструментов -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <h2 class="text-3xl font-bold text-center text-gray-900 mb-4">
      Professional GHS Tools
    </h2>
    <p class="text-center text-gray-500 mb-12">Free tools trusted by EHS engineers and chemists</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- ATE Calculator -->
      <a href="/tools/ate-calculator" class="group border border-gray-200 rounded-2xl p-8 hover:border-blue-300 hover:shadow-lg transition-all">
        <div class="text-4xl mb-4">⚗️</div>
        <h3 class="text-xl font-bold text-gray-900 group-hover:text-blue-700 transition-colors">
          Mixture ATE Calculator
        </h3>
        <p class="mt-3 text-gray-600">
          Calculate acute toxicity estimate (ATE) for chemical mixtures
          using the GHS formula. Get PDF report for your SDS.
        </p>
        <span class="mt-4 inline-block text-sm font-medium text-blue-700">
          Try Calculator →
        </span>
      </a>

      <!-- Storage Matrix -->
      <a href="/tools/storage-matrix" class="group border border-gray-200 rounded-2xl p-8 hover:border-blue-300 hover:shadow-lg transition-all">
        <div class="text-4xl mb-4">🗄️</div>
        <h3 class="text-xl font-bold text-gray-900 group-hover:text-blue-700 transition-colors">
          Chemical Storage Matrix
        </h3>
        <p class="mt-3 text-gray-600">
          Check which chemicals can be stored together safely.
          Color-coded compatibility matrix based on GHS segregation rules.
        </p>
        <span class="mt-4 inline-block text-sm font-medium text-blue-700">
          Check Compatibility →
        </span>
      </a>
    </div>
  </section>

  <!-- База данных -->
  <section class="bg-blue-950 py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-white">
        5,000+ Chemicals Database
      </h2>
      <p class="mt-4 text-blue-200">
        Harmonized classifications from ECHA CLP Annex VI.
        H-statements, P-statements, pictograms, signal words, ATE values.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/hazards" class="bg-orange-500 text-white px-8 py-3 rounded-lg font-semibold hover:bg-orange-600 transition-colors">
          Browse Chemicals Database
        </a>
      </div>
      <div class="mt-8 grid grid-cols-3 gap-6 max-w-lg mx-auto text-center">
        <div>
          <div class="text-2xl font-bold text-white">4,178</div>
          <div class="text-blue-300 text-sm">Substances</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-white">9</div>
          <div class="text-blue-300 text-sm">GHS Pictograms</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-white">100%</div>
          <div class="text-blue-300 text-sm">CLP Annex VI</div>
        </div>
      </div>
    </div>
  </section>
</Layout>
