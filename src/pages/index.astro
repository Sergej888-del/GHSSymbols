---
// Главная страница ghssymbols.com
import Layout from '../layouts/Layout.astro'
---

<Layout
  title="GHS Hazard Symbols & Chemical Safety Tools"
  description="Free GHS/CLP tools for EHS professionals: ATE mixture toxicity calculator, chemical storage compatibility matrix, H-statements database."
>
  <!-- Hero секция -->
  <section class="bg-gradient-to-br from-orange-50 to-white py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 leading-tight">
        GHS Hazard Symbols &<br />
        <span class="text-orange-600">Chemical Safety Tools</span>
      </h1>
      <p class="mt-6 text-xl text-gray-600 max-w-2xl mx-auto">
        Professional tools for EHS specialists: calculate mixture toxicity,
        check chemical storage compatibility, look up H/P-statements.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/tools/ate-calculator"
          class="bg-orange-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-orange-700 transition-colors"
        >
          ATE Calculator
        </a>
        <a
          href="/tools/storage-matrix"
          class="border border-gray-300 text-gray-700 px-8 py-3 rounded-lg font-semibold hover:border-orange-400 hover:text-orange-600 transition-colors"
        >
          Storage Matrix
        </a>
      </div>
    </div>
  </section>

  <!-- Карточки инструментов -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">
      Professional GHS Tools
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Инструмент 1: ATE Calculator -->
      <a href="/tools/ate-calculator" class="group border border-gray-200 rounded-2xl p-8 hover:border-orange-300 hover:shadow-lg transition-all">
        <div class="text-4xl mb-4">⚗️</div>
        <h3 class="text-xl font-bold text-gray-900 group-hover:text-orange-600 transition-colors">
          Mixture ATE Calculator
        </h3>
        <p class="mt-3 text-gray-600">
          Calculate acute toxicity estimate (ATE) for chemical mixtures
          using the GHS formula. Get PDF report for your SDS.
        </p>
        <span class="mt-4 inline-block text-sm font-medium text-orange-600">
          Try Calculator →
        </span>
      </a>

      <!-- Инструмент 2: Storage Matrix -->
      <a href="/tools/storage-matrix" class="group border border-gray-200 rounded-2xl p-8 hover:border-orange-300 hover:shadow-lg transition-all">
        <div class="text-4xl mb-4">🗄️</div>
        <h3 class="text-xl font-bold text-gray-900 group-hover:text-orange-600 transition-colors">
          Chemical Storage Matrix
        </h3>
        <p class="mt-3 text-gray-600">
          Check which chemicals can be stored together safely.
          Color-coded compatibility matrix based on GHS segregation rules.
        </p>
        <span class="mt-4 inline-block text-sm font-medium text-orange-600">
          Check Compatibility →
        </span>
      </a>
    </div>
  </section>

  <!-- SEO секция: база данных -->
  <section class="bg-gray-50 py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-gray-900">
        5,000+ Chemicals Database
      </h2>
      <p class="mt-4 text-gray-600">
        Harmonized classifications from ECHA CLP Annex VI.
        H-statements, pictograms, signal words, ATE values.
      </p>
      <a href="/hazards" class="mt-8 inline-block border border-gray-300 text-gray-700 px-6 py-3 rounded-lg font-medium hover:border-orange-400 hover:text-orange-600 transition-colors">
        Browse Chemicals Database
      </a>
    </div>
  </section>
</Layout>
