---
import Layout from '../../layouts/Layout.astro'
import SubstancePage from '../../components/SubstancePage'
import { supabase } from '../../lib/supabase'

export async function getStaticPaths() {
  const { data: substances } = await supabase
    .from('substances')
    .select('cas_number, iupac_name, common_name')
    .not('cas_number', 'is', null)

  return (substances || []).map((s) => ({
    params: { cas: s.cas_number },
    props: { name: s.common_name || s.iupac_name }
  }))
}

const { cas } = Astro.params
const { name } = Astro.props
---

<Layout
  title={`${name} — GHS Hazard Information`}
  description={`GHS/CLP hazard classification, H-statements and pictograms for ${name}. CAS ${cas}.`}
  canonical={`https://ghssymbols.com/hazards/${cas}`}
>
  <SubstancePage client:load initialCas={cas} />
</Layout>
