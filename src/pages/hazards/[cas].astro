---
import Layout from '../../layouts/Layout.astro'
import SubstancePage from '../../components/SubstancePage'
import { supabase } from '../../lib/supabase'

export async function getStaticPaths() {
  let allSubstances: { cas_number: string; iupac_name: string; common_name: string | null }[] = []
  let from = 0
  const pageSize = 1000

  while (true) {
    const { data } = await supabase
      .from('substances')
      .select('cas_number, iupac_name, common_name')
      .not('cas_number', 'is', null)
      .range(from, from + pageSize - 1)

    if (!data || data.length === 0) break
    allSubstances = [...allSubstances, ...data]
    if (data.length < pageSize) break
    from += pageSize
  }

  return allSubstances.map((s) => ({
    params: { cas: s.cas_number },
    props: { name: s.common_name || s.iupac_name }
  }))
}

const { cas } = Astro.params
const { name } = Astro.props
---

<Layout
  title={`${name} — GHS Hazard Information`}
  description={`GHS/CLP hazard classification, H-statements and pictograms for ${name}. CAS ${cas}.`}
  canonical={`https://ghssymbols.com/hazards/${cas}`}
>
  <SubstancePage client:load initialCas={cas} />
</Layout>
